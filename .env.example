# Local MT5 optimizer — only your TradeEcho User ID is required.
# Copy to `.env` in this folder. Never commit real values.
# Scripts: `python mt5_heartbeat.py`, … — see README.md.

# Your User ID from TradeEcho dashboard → Setup (Ultimate plan required)
TRADEECHO_USER_ID=

# Optional — defaults to ./SetFiles (gitignored; add your .set grids there)
# MT5_SET_DIR=

# Compiled EA in MQL5\Experts (required for optimize + dashboard Start/Resume)
MT5_EXPERT=

# Optional — TradeEcho API host (defaults to https://trade-echo.com)
# TRADEECHO_API_BASE_URL=https://trade-echo.com

# Local dev only — skip Ultimate subscription API check
# TRADEECHO_SKIP_ACCESS_CHECK=1
